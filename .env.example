# Copy to .env.local for local dev, and set these in the Vercel dashboard
# (Project → Settings → Environment Variables) for production.

# Admin login password for /admin
ADMIN_PASSWORD=change-me

# Random 64-char hex string used to sign the admin session cookie.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Supabase — required in production so the admin panel can save content and
# uploads (Vercel's filesystem is read-only). Leave blank locally to use the
# filesystem instead. Get these from Supabase: Settings → API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
